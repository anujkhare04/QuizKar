{
  "version": 2,
  "builds": [
    { "src": "frontendx/package.json", "use": "@vercel/static-build" },
    { "src": "quizbackend/api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "quizbackend/api/index.js" },
    { "src": "/(.*)", "dest": "frontendx/$1" }
  ]
}
